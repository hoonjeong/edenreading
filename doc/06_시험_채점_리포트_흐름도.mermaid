%% ====================================================
%% 시험 출제 → 자동 채점 → 리포트 생성 상세 흐름 (Level 3)
%% 가장 핵심적인 차별 기능을 별도로 상세하게 표현
%% ====================================================

flowchart TD
    Start([시험 관리 진입]) --> A[새 시험 회차 생성]

    %% ===== 시험 정보 입력 단계 =====
    A --> B[시험 기본 정보 입력]
    B --> B1[시험명]
    B --> B2[시험 일자]
    B --> B3[총 문항 수]
    B --> B4[학년/대상 구분]
    B1 & B2 & B3 & B4 --> C[문항별 정보 입력]

    C --> C1[문항 번호]
    C --> C2[문제 유형 선택<br/>어휘/독해/문법/추론 등]
    C --> C3[배점 입력]
    C --> C4[정답 입력]
    C1 & C2 & C3 & C4 --> D{모든 문항 입력 완료?}
    D -- 아니오 --> C
    D -- 예 --> E[시험 마스터 저장]

    %% ===== 학생 배정 =====
    E --> F[응시 학생 배정]
    F --> F1[전체 학생 목록 표시]
    F1 --> F2[응시자 다중 선택]
    F2 --> F3[배정 완료]

    %% ===== 답안 입력 =====
    F3 --> G[학생별 답안 입력 화면]
    G --> G1[학생 선택]
    G1 --> G2[답안지 보며<br/>1번부터 순차 입력]
    G2 --> G3{입력 완료?}
    G3 -- 아니오 --> G2
    G3 -- 예 --> H[자동 채점 트리거]

    %% ===== 자동 채점 =====
    H --> H1[정답 vs 답안 비교]
    H1 --> H2[문항별 정오 판정]
    H2 --> H3[총점 계산<br/>배점 합산]
    H3 --> H4[영역별 정답률 산출<br/>어휘 80%, 독해 60% ...]
    H4 --> I[결과 데이터 저장]

    I --> J{모든 학생 입력?}
    J -- 아니오 --> G1
    J -- 예 --> K[리포트 생성 단계]

    %% ===== 리포트 생성 =====
    K --> K1[학생별 개별 리포트]
    K1 --> K1a[종합 점수 및 등급]
    K1 --> K1b[영역별 정답률 - 막대 그래프]
    K1 --> K1c[회차별 점수 추이 - 라인 그래프]
    K1 --> K1d[강점/약점 영역 자동 분석]
    K1 --> K1e[유사 학년 평균 대비 위치]

    K --> K2[관리자용 종합 리포트]
    K2 --> K2a[전체 학생 점수 분포]
    K2 --> K2b[문항별 정답률 - 난이도 분석]
    K2 --> K2c[영역별 평균 정답률]

    K1a & K1b & K1c & K1d & K1e --> L[관리자 검토]

    %% ===== 학부모 공유 =====
    L --> M{공유 시점 결정}
    M -- 즉시 일괄 공유 --> N1[전체 학부모 알림]
    M -- 개별 검토 후 공유 --> N2[학생별 개별 공유]
    M -- 코멘트 추가 후 --> N3[선생님 코멘트 작성]
    N3 --> N1

    N1 --> O[학부모 페이지에 리포트 게시]
    N2 --> O
    O --> P[학부모 알림 수신<br/>카톡/SMS/Push]
    P --> Q([학부모, 자녀 리포트 열람])

    %% ===== 사후 관리 =====
    Q -.선택.-> R[학부모, 상담 신청]
    R -.-> S[관리자 상담 일정 조율]

    %% ===== 스타일 =====
    classDef start fill:#E8F5E9,stroke:#388E3C,stroke-width:2px,color:#1B5E20
    classDef setup fill:#E3F2FD,stroke:#1976D2,stroke-width:2px,color:#0D47A1
    classDef process fill:#FFF3E0,stroke:#F57C00,stroke-width:2px,color:#E65100
    classDef report fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px,color:#4A148C
    classDef share fill:#FCE4EC,stroke:#C2185B,stroke-width:2px,color:#880E4F
    classDef decision fill:#FFF9C4,stroke:#F9A825,stroke-width:2px,color:#F57F17

    class Start,Q start
    class A,B,C,E,F,F3 setup
    class G,H,H1,H2,H3,H4,I process
    class K,K1,K2,K1a,K1b,K1c,K1d,K1e,K2a,K2b,K2c report
    class L,M,N1,N2,N3,O,P share
    class D,G3,J decision
