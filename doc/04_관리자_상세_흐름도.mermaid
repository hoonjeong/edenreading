%% ====================================================
%% 관리자 상세 흐름도 (Level 2)
%% 관리자가 시스템에서 수행하는 모든 핵심 업무 흐름
%% ====================================================

flowchart TD
    AdminLogin([관리자 로그인]) --> Dash[대시보드<br/>오늘의 알림·요약]

    %% ===== 1. 회원 관리 =====
    Dash --> M1[회원 관리 메뉴]
    M1 --> M1a[관리자 회원 추가]
    M1 --> M1b[권한 설정<br/>원장/선생님]
    M1 --> M1c[내 정보 수정]

    %% ===== 2. 학부모/학생 관리 =====
    Dash --> R1[학부모/학생 관리]
    R1 --> R2[학부모 신규 등록]
    R2 --> R3[기본 정보 입력]
    R3 --> R4[6자리 인증코드 자동 생성]
    R4 --> R5{발송 방식 선택}
    R5 -- 카톡 --> R6[알림톡 발송]
    R5 -- SMS --> R7[문자 발송]
    R5 -- 직접 전달 --> R8[코드 화면 표시]

    R1 --> S1[학생 신규 등록]
    S1 --> S2[학생 정보 입력<br/>이름/학년/특이사항]
    S2 --> S3[학부모 연동<br/>1:N, N:1 가능]
    S3 --> S4[학생 카드 생성 완료]

    %% ===== 3. 활동 기록 =====
    Dash --> AC1[주간 활동 기록]
    AC1 --> AC2[학생 선택]
    AC2 --> AC3[활동 일자 선택]
    AC3 --> AC4[콘텐츠 업로드]
    AC4 --> AC4a[사진 첨부]
    AC4 --> AC4b[영상 첨부]
    AC4 --> AC4c[활동 글 작성]
    AC4a & AC4b & AC4c --> AC5{공유 여부}
    AC5 -- 즉시 공유 --> AC6[학부모 알림 발송]
    AC5 -- 임시 저장 --> AC7[비공개 저장]
    AC6 --> AC8[활동 카드 등록 완료]
    AC7 --> AC9[추후 수정·공유 가능]

    AC8 --> AC10[이전 활동 수정/삭제]

    %% ===== 4. 시험 관리 =====
    Dash --> T1[시험 관리]
    T1 --> T2[신규 시험 회차 생성]
    T2 --> T3[시험 기본 정보 입력<br/>시험명/일자/총 문항 수]
    T3 --> T4[문항별 정보 입력<br/>번호/유형/배점]
    T4 --> T5[정답 입력]
    T5 --> T6[응시 학생 배정]
    T6 --> T7[학생별 답안 입력]
    T7 --> T8[자동 채점 실행]
    T8 --> T9[리포트 자동 생성<br/>회차별/영역별 분석]
    T9 --> T10{학부모 공유?}
    T10 -- 예 --> T11[학부모 알림 + 리포트 게시]
    T10 -- 검토 후 --> T12[관리자 검토 대기]
    T12 --> T11

    T1 --> T13[기존 시험 수정/삭제]

    %% ===== 5. 독서 기록 =====
    Dash --> B1[독서 기록 관리]
    B1 --> B2[학생 선택]
    B2 --> B3[책 정보 입력<br/>제목/저자/표지]
    B3 --> B4[독서 활동 기록<br/>사진/소감]
    B4 --> B5[학부모 공유]

    %% ===== 6. 학부모 소통 =====
    Dash --> C1[학부모 소통]
    C1 --> C2[메시지 발송]
    C2 --> C2a[수신 대상 선택<br/>개별/반/전체]
    C2a --> C2b{발송 채널}
    C2b -- 카카오톡 --> C2c[알림톡 발송]
    C2b -- 문자 --> C2d[SMS 발송]
    C2b -- 앱 알림 --> C2e[Push 발송]
    C2c & C2d & C2e --> C2f[발송 이력 저장]

    C1 --> C3[상담 관리]
    C3 --> C3a[신규 상담 요청 확인]
    C3a --> C3b[일정 조율 및 확정]
    C3b --> C3c[상담 진행 후 기록 저장]
    C3c --> C3d[학생 카드에 누적 표시]

    %% ===== 7. 출석 관리 =====
    Dash --> AT1[출석 관리]
    AT1 --> AT2[일자 선택]
    AT2 --> AT3[학생별 출결 체크<br/>출석/지각/결석]
    AT3 --> AT4[저장 - 학부모 자동 알림]
    AT1 --> AT5[월별/기간별 통계 조회]

    %% ===== 스타일 =====
    classDef start fill:#E8F5E9,stroke:#388E3C,stroke-width:2px,color:#1B5E20
    classDef main fill:#E3F2FD,stroke:#1976D2,stroke-width:2px,color:#0D47A1
    classDef action fill:#F3E5F5,stroke:#7B1FA2,stroke-width:1px,color:#4A148C
    classDef decision fill:#FFF9C4,stroke:#F9A825,stroke-width:2px,color:#F57F17
    classDef done fill:#FFE0B2,stroke:#F57C00,stroke-width:2px,color:#E65100

    class AdminLogin start
    class Dash,M1,R1,S1,AC1,T1,B1,C1,C3,AT1 main
    class R5,AC5,T10,C2b decision
    class AC8,T11,C2f,C3d,AT4 done
